generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PlanType {
  NORMAL
  PRO
}

enum UserRole {
  OWNER
  ADMIN
  STAFF
}

/**
 * Rol de equipo para gestión de miembros (Mi Equipo).
 * Reemplaza el catálogo global roles_taller de Supabase.
 */
enum TeamRole {
  ADMINISTRADOR
  TECNICO
  RECEPCIONISTA
  REPARADOR
}

enum ArchivoTipo {
  REPAIR_PHOTO
  REPAIR_INTAKE_PHOTO
  REPAIR_EVIDENCE_PHOTO
  PRODUCT_PHOTO
  BUDGET_ATTACHMENT
  SIGNATURE
  HIKVISION_SNAPSHOT
  VISIT_PHOTO
  OTHER
}

enum ArchivoVisibility {
  PUBLIC_TRACK
  PRIVATE
  TRACKING_VERIFIED
  PUBLIC
  PRO_PRIVATE
}

model Tenant {
  id            String   @id @default(cuid())
  nombre        String
  slug          String   @unique
  plan          PlanType @default(NORMAL)
  trialEndsAt   DateTime?
  timezone      String   @default("America/Mexico_City")
  currency      String   @default("MXN")
  logoUrl       String?
  paperSize     String?  @default("80mm")
  printSettings Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  users              User[]
  clientes           Cliente[]
  reparaciones       Reparacion[]
  archivos           Archivo[]
  configuracion      ConfiguracionTaller?
  productos          Producto[]
  historialReparaciones HistorialReparacion[]
  catalogoServicios      CatalogoServicio[]
  serviciosReparacion    ReparacionServicio[]
  ventas             Venta[]
  cajas              Caja[]
  movimientosCaja    MovimientoCaja[]
  gastosOperativos   GastoOperativo[]
  gastosReparacion   GastoReparacion[]
  visitas            Visita[]
  workshopMessages   WorkshopMessage[]
  proveedores        Proveedor[]
  ordenesCompra      OrdenCompra[]
  comprasUsadas      CompraUsada[]
  cotizaciones       Cotizacion[]
  cotizacionItems    CotizacionItem[]
}

model User {
  id        String   @id @default(cuid())
  tenantId  String
  email     String   @unique
  nombre    String
  passwordHash String
  emailVerified Boolean @default(true)
  sessionVersion Int @default(1)
  role      UserRole @default(STAFF)
  /** Rol de equipo para gestión de miembros (Mi Equipo). */
  teamRole  TeamRole?
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  accounts Account[]
  sessions Session[]

  @@unique([tenantId, email])
  @@index([tenantId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  tenantId          String?
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@index([tenantId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  tenantId     String?
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Cliente {
  id        String   @id @default(cuid())
  tenantId  String
  nombre    String
  telefono  String?
  telefonoSecundario String?
  email     String?
  notas     String?
  rfc       String?
  razonSocial String?
  codigoPostalFiscal String?
  regimenFiscal String?
  usoCfdi   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reparaciones Reparacion[]

  @@index([tenantId])
  @@index([tenantId, telefono])
}

model Reparacion {
  id           String   @id @default(cuid())
  tenantId     String
  clienteId    String
  folio        String
  estado       String   @default("RECIBIDO") @map("estatus")
  tipoEquipo   String?
  equipoMarca  String?
  equipoModelo String?
  numeroSerie  String?
  color        String?
  falla        String?
  tecnico      String?
  costoEstimado Decimal? @db.Decimal(10, 2) @map("precio_estimado")
  anticipo     Decimal? @db.Decimal(10, 2)
  securityType String?
  securityValue String?
  pinContrasena String?
  patronDesbloqueo String?
  notasInternas String?
  checklistIngreso Json?
  checklistPro  Json?      @map("checklist_pro")
  creadoPorNombre String?  @map("creado_por_nombre")
  costoTotal   Decimal?  @db.Decimal(12, 2) @map("costo_total")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cliente  Cliente  @relation(fields: [clienteId], references: [id], onDelete: Restrict)
  archivos Archivo[]
  historial HistorialReparacion[]
  gastosReparacion GastoReparacion[]
  serviciosReparacion ReparacionServicio[]

  @@unique([tenantId, folio])
  @@index([tenantId])
  @@index([clienteId])
}

/**
 * Historial unificado de actividad por reparación.
 * Reemplaza las tablas legacy historial_reparacion + cambios_reparaciones.
 */
model HistorialReparacion {
  id              String   @id @default(cuid())
  tenantId        String
  reparacionId    String
  /** "estado" | "abono" | "presupuesto" | "tecnico" | "creacion" | "otro" */
  tipo            String
  /** Descripción legible del cambio (ej: "Estado: Recibido -> Diagnostico") */
  descripcion     String
  valorAnterior   String?
  valorNuevo      String?
  actorNombre     String?
  nota            String?
  createdAt       DateTime @default(now())

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reparacion Reparacion  @relation(fields: [reparacionId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([reparacionId])
  @@index([tenantId, reparacionId, createdAt])
}

model Archivo {
  id           String   @id @default(cuid())
  tenantId     String
  reparacionId String?
  productoId   String?
  tipo         ArchivoTipo?
  visibility   ArchivoVisibility?
  bucket       String
  key          String
  storageKey   String?
  publicUrl    String?
  fileName     String?
  mimeType     String?
  sizeBytes    Int?
  size         Int?
  sortOrder    Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reparacion Reparacion? @relation(fields: [reparacionId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([reparacionId])
  @@index([productoId])
}

model ConfiguracionTaller {
  id                   String   @id @default(cuid())
  tenantId             String   @unique
  nombreComercial      String?
  direccion            String?
  telefono             String?
  emailContacto        String?
  ciudad               String?
  estado               String?
  pais                 String?
  moneda               String?  @default("MXN")
  timezone             String?  @default("America/Mexico_City")
  logoUrl              String?
  logoStorageKey       String?
  whatsapp             String?
  paperSize            String?  @default("80mm")
  labelSize            String?  @default("2x1")
  printSettings        Json?
  terminosGarantia     String?
  diasGarantia         Int?     @default(30)
  mensajeDespedida     String?
  alertasStockBajo     Boolean? @default(false)
  reportesCierreCaja   Boolean? @default(true)
  alertaUrgentes       Boolean? @default(false)
  prefijoFolio         String?  @default("REP")
  siguienteFolio       Int?     @default(1)
  facebook             String?
  instagram            String?
  tiktok               String?
  camaraConfig         Json?    @map("camara_config")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Producto {
  id             String     @id @default(cuid())
  tenantId       String     @map("taller_id")
  nombre         String
  sku            String?
  codigoBarras   String?    @map("codigo_barras")
  imagenUrl      String?    @map("imagen_url")
  categoria      String?
  descripcion    String?
  marca          String?
  modelo         String?
  ubicacion      String?
  costo          Decimal    @default(0) @db.Decimal(12, 2)
  precioVenta    Decimal    @default(0) @db.Decimal(12, 2) @map("precio_venta")
  stockActual    Int        @default(0) @map("stock_actual")
  stockMinimo    Int        @default(0) @map("stock_minimo")
  esEquipo       Boolean    @default(false) @map("es_equipo")
  imeiSerie      String?    @map("imei_serie")
  color          String?
  capacidad      String?
  procesador     String?
  ram            String?
  almacenamiento String?
  condicion      String?
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt

  tenant         Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("productos")
  @@index([tenantId])
  @@index([tenantId, categoria])
}

/**
 * Venta de mostrador (POS).
 * Tabla legacy creada via raw SQL, nombre lowercase.
 */
model Venta {
  id                 String   @id @default(cuid())
  tenantId           String   @map("taller_id")
  cajaId             String?  @map("caja_id")
  folio              String
  clienteNombre      String?  @map("cliente_nombre")
  clienteId          String?  @map("cliente_id")
  clienteTelefono    String?  @map("cliente_telefono")
  total              Decimal  @default(0) @db.Decimal(12, 2)
  descuento          Decimal  @default(0) @db.Decimal(12, 2)
  metodoPago         String   @default("efectivo") @map("metodo_pago")
  montoEfectivo      Decimal  @default(0) @db.Decimal(12, 2) @map("monto_efectivo")
  montoTarjeta       Decimal  @default(0) @db.Decimal(12, 2) @map("monto_tarjeta")
  montoTransferencia Decimal  @default(0) @db.Decimal(12, 2) @map("monto_transferencia")
  cambio             Decimal  @default(0) @db.Decimal(12, 2)
  estado             String   @default("activa")
  vendedorNombre     String?  @map("vendedor_nombre")
  createdAt          DateTime @default(now()) @map("created_at")

  tenant   Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  caja     Caja?         @relation(fields: [cajaId], references: [id])
  detalles DetalleVenta[]

  @@map("ventas")
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([cajaId])
}

/**
 * Linea individual dentro de una venta de mostrador.
 */
model DetalleVenta {
  id             String   @id @default(cuid())
  ventaId        String   @map("venta_id")
  productoId     String?  @map("producto_id")
  descripcion    String
  cantidad       Int      @default(1)
  precioUnitario Decimal  @db.Decimal(12, 2) @map("precio_unitario")
  costoUnitario  Decimal  @default(0) @db.Decimal(12, 2) @map("costo_unitario")
  subtotal       Decimal  @default(0) @db.Decimal(12, 2)
  esEspecial     Boolean  @default(false) @map("es_especial")
  imeiSerie      String?  @map("imei_serie")
  color          String?
  condicion      String?
  marca          String?
  modelo         String?
  categoria      String?
  procesador     String?
  ram            String?
  almacenamiento String?
  createdAt      DateTime @default(now()) @map("created_at")

  venta Venta @relation(fields: [ventaId], references: [id], onDelete: Cascade)

  @@map("detalle_ventas")
  @@index([ventaId])
}

/**
 * Caja diaria (corte de caja).
 * Tabla legacy creada via raw SQL, nombre lowercase.
 */
model Caja {
  id                 String   @id @default(cuid())
  tenantId           String   @map("taller_id")
  montoInicial       Decimal  @default(0) @db.Decimal(12, 2) @map("monto_inicial")
  montoCierre        Decimal? @db.Decimal(12, 2) @map("monto_cierre")
  fechaApertura      DateTime @default(now()) @map("fecha_apertura")
  fechaCierre        DateTime? @map("fecha_cierre")
  estado             String   @default("abierta")
  totalEfectivo      Decimal  @default(0) @db.Decimal(12, 2) @map("total_efectivo")
  totalTarjeta       Decimal  @default(0) @db.Decimal(12, 2) @map("total_tarjeta")
  totalTransferencia Decimal  @default(0) @db.Decimal(12, 2) @map("total_transferencia")
  totalVentas        Int      @default(0) @map("total_ventas")
  notaCierre         String?  @map("nota_cierre")
  numeroCorte        Int?     @map("numero_corte")

  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ventas      Venta[]
  movimientos MovimientoCaja[]

  @@map("caja")
  @@index([tenantId])
  @@index([tenantId, estado])
}

/**
 * Movimiento de caja (ventas PDV, abonos reparaciones, gastos).
 * Tabla legacy creada via raw SQL, nombre lowercase.
 */
model MovimientoCaja {
  id             String   @id @default(cuid())
  tenantId       String   @map("taller_id")
  cajaId         String?  @map("caja_id")
  tipo           String
  referenciaId   String?  @map("referencia_id")
  descripcion    String?
  monto          Decimal  @default(0) @db.Decimal(12, 2)
  metodoPago     String?  @map("metodo_pago")
  fecha          DateTime @default(now())
  folio          String?
  vendedorNombre String?  @map("vendedor_nombre")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  caja   Caja?  @relation(fields: [cajaId], references: [id], onDelete: SetNull)

  @@map("movimientos_caja")
  @@index([tenantId])
  @@index([tenantId, fecha])
  @@index([cajaId])
   @@index([tipo])
}

/**
 * Gasto operativo del taller (Bitácora de Gastos).
 * Tabla legacy creada via raw SQL en Supabase, ahora gestionada por Prisma.
 */
model GastoOperativo {
  id         String   @id @default(cuid())
  tenantId   String   @map("taller_id")
  concepto   String
  categoria  String   @default("general")
  monto      Decimal  @db.Decimal(10, 2)
  metodoPago String   @default("efectivo") @map("metodo_pago")
  fecha      DateTime
  notas      String?
  cajaId     String?  @map("caja_id")
  createdAt  DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("bitacora_gastos")
  @@index([tenantId])
  @@index([tenantId, fecha])
}

/**
 * Gasto asociado a un ticket de reparación (inversión).
 * Tabla legacy creada via raw SQL en Supabase, ahora gestionada por Prisma.
 */
model GastoReparacion {
  id              String   @id @default(cuid())
  tenantId        String   @map("taller_id")
  reparacionId    String   @map("reparacion_id")
  concepto        String
  monto           Decimal  @db.Decimal(10, 2)
  tipo            String
  productoId      String?  @map("producto_id")
  mostrarCliente  Boolean  @default(false) @map("mostrar_cliente")
  creadoPorNombre String?  @map("creado_por_nombre")
  createdAt       DateTime @default(now()) @map("created_at")

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reparacion Reparacion @relation(fields: [reparacionId], references: [id], onDelete: Cascade)

  @@map("reparacion_gastos")
  @@index([tenantId])
  @@index([tenantId, reparacionId])
}

model CatalogoServicio {
  id          String   @id @default(cuid())
  tenantId    String   @map("taller_id")
  nombre      String
  descripcion String   @default("")
  precio      Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("catalogo_servicios")
  @@index([tenantId])
}

model Visita {
  id                String    @id @default(cuid())
  tenantId          String    @map("taller_id")
  fechaLlegada      DateTime  @default(now()) @map("fecha_hora_entrada")
  fechaSalida       DateTime? @map("fecha_hora_salida")
  fotoEntradaUrl    String?   @map("foto_entrada_url")
  fotoSalidaUrl     String?   @map("foto_salida_url")
  camaraIp          String?   @map("camara_ip")
  eventoTipo        String?   @default("manual") @map("evento_tipo")
  motivo            String?   @map("motivo_visita")
  motivoOtro        String?   @map("motivo_otro")
  estado            String    @default("pendiente") @map("estado_atencion")
  reparacionFolio   String?   @map("reparacion_folio")
  ventaFolio        String?   @map("venta_folio")
  atendidoPor       String?   @map("atendido_por")
  notas             String?
  clienteNombre     String?   @map("cliente_nombre")
  clienteTelefono   String?   @map("cliente_telefono")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("bitacora_visitas")
  @@index([tenantId])
  @@index([tenantId, fechaLlegada])
}

model ReparacionServicio {
  id             String   @id @default(cuid())
  tenantId       String   @map("taller_id")
  reparacionId   String   @map("reparacion_id")
  servicioId     String?  @map("servicio_id")
  nombreSnapshot  String   @map("nombre_snapshot")
  precioSnapshot  Decimal  @db.Decimal(10, 2) @map("precio_snapshot")
  cantidad       Int      @default(1)
  createdAt      DateTime @default(now()) @map("created_at")

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reparacion Reparacion @relation(fields: [reparacionId], references: [id], onDelete: Cascade)

  @@map("reparacion_servicios")
  @@index([tenantId])
  @@index([reparacionId])
}

model WorkshopMessage {
  id         String   @id @default(cuid())
  tenantId   String   @map("taller_id")
  senderId   String?  @map("sender_id")
  senderName String   @default("Tecnico") @map("sender_name")
  content    String
  recipientId String? @map("recipient_id")
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("workshop_messages")
  @@index([tenantId])
  @@index([tenantId, createdAt])
}

model Proveedor {
  id        String   @id @default(cuid())
  tenantId  String   @map("taller_id")
  nombre    String
  contacto  String?
  telefono  String?
  email     String?
  notas     String?
  activo    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ordenes OrdenCompra[]

  @@map("proveedores")
  @@index([tenantId])
}

model OrdenCompra {
  id               String    @id @default(cuid())
  tenantId         String    @map("taller_id")
  folio            String
  proveedorId      String?   @map("proveedor_id")
  proveedorNombre  String    @default("") @map("proveedor_nombre")
  estatus          String    @default("borrador")
  total            Decimal   @default(0) @db.Decimal(12, 2)
  notas            String?
  fechaOrden       DateTime  @map("fecha_orden") @db.Date
  fechaEntrega     DateTime? @map("fecha_entrega") @db.Date
  stockAplicado    Boolean   @default(false) @map("stock_aplicado")
  custodio         String?
  erroresRecepcion Json?     @map("errores_recepcion")
  createdAt        DateTime  @default(now()) @map("created_at")

  tenant    Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  proveedor Proveedor?         @relation(fields: [proveedorId], references: [id])
  detalles  DetalleOrdenCompra[]

  @@map("ordenes_compra")
  @@index([tenantId])
}

model DetalleOrdenCompra {
  id            String   @id @default(cuid())
  tenantId      String   @map("taller_id")
  ordenId       String   @map("orden_id")
  descripcion   String
  cantidad      Decimal  @db.Decimal(10, 2)
  precioUnitario Decimal @db.Decimal(12, 2) @map("precio_unitario")
  subtotal      Decimal  @db.Decimal(12, 2)
  productoId    String?  @map("producto_id")
  createdAt     DateTime @default(now()) @map("created_at")

  orden OrdenCompra @relation(fields: [ordenId], references: [id], onDelete: Cascade)

  @@map("detalle_orden_compra")
  @@index([ordenId])
  @@index([tenantId])
}

model CompraUsada {
  id            String   @id @default(cuid())
  tenantId      String   @map("taller_id")
  folio         String
  fecha         DateTime @default(now())
  vendedor      String
  documento     String
  telefono      String?
  marca         String
  modelo        String
  serial        String?
  imei          String?
  color         String?
  condicion     String?
  capacidad     String?
  monto         Decimal  @db.Decimal(12, 2)
  observaciones String?
  actorNombre   String?  @map("actor_nombre")
  createdAt     DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("compras_usadas")
  @@index([tenantId])
}

model Cotizacion {
  id              String   @id @default(uuid())
  tenantId        String   @map("taller_id")
  folio           String
  clienteId       String?  @map("cliente_id")
  clienteNombre   String   @map("cliente_nombre")
  clienteTelefono String?  @map("cliente_telefono")
  equipoTipo      String   @default("Celular") @map("equipo_tipo")
  marca           String   @default("")
  modelo          String   @default("")
  descripcion     String   @default("")
  observaciones   String?
  subtotal        Decimal  @db.Decimal(12, 2)
  descuento       Decimal  @db.Decimal(12, 2)
  total           Decimal  @db.Decimal(12, 2)
  estado          String   @default("pendiente")
  fecha           DateTime @default(now())
  fechaExpiracion DateTime? @map("fecha_expiracion")
  creadoPor       String?  @map("creado_por")
  reparacionId    String?  @map("reparacion_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @map("updated_at")

  tenant Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items  CotizacionItem[]

  @@unique([tenantId, folio])
  @@map("cotizaciones")
  @@index([tenantId])
  @@index([tenantId, estado])
}

model CotizacionItem {
  id             String   @id @default(uuid())
  tenantId       String   @map("taller_id")
  cotizacionId   String   @map("cotizacion_id")
  descripcion    String
  cantidad       Decimal  @db.Decimal(12, 2)
  precioUnitario Decimal  @db.Decimal(12, 2) @map("precio_unitario")
  total          Decimal  @db.Decimal(12, 2)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @default(now()) @map("updated_at")

  cotizacion Cotizacion @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)
  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("cotizacion_items")
  @@index([tenantId])
  @@index([cotizacionId])
}
